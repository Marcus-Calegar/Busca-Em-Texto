# Visual Studio / .NET gitignore
# See http://github.com/github/gitignore/blob/main/VisualStudio.gitignore for reference

## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
**/[Bb]in/
**/[Oo]bj/

# Visual Studio cache/options folders
.vs/
*.VC.db
*.VC.VC.opendb

# Rider
.idea/

# Resharper
_ReSharper*/
*.DotSettings.user

# NuGet
packages/
*.nupkg
.nuget/
project.lock.json
project.fragment.lock.json

# TeamCity
.teamcity/

# Build and test results
TestResults/
*.trx
*.log

# Publish outputs
Publish/
*.Publish.xml

# IIS Express
/.vs/**/applicationhost.config

# Others
*.dbmdl
*.jfm
Thumbs.db
ehthumbs.db
